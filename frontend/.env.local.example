# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# VK ID (One Tap) — ID приложения из https://id.vk.com/
# Должен совпадать с VK_CLIENT_ID в backend/.env
NEXT_PUBLIC_VK_APP_ID=54435093

# Яндекс ID (кнопка из конструктора) — https://yandex.ru/dev/id/doc/ru/suggest/but-const
# Должен совпадать с YANDEX_CLIENT_ID в backend/.env. В OAuth-приложении добавьте Redirect URI: https://ваш-домен/auth/yandex-token
NEXT_PUBLIC_YANDEX_CLIENT_ID=

# Яндекс.Карты API Key
# Get API key at: https://developer.tech.yandex.ru/
# Required for map functionality
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-maps-api-key
